{
	"name": "obsidian-delta-stream",
	"version": "0.1.0",
	"description": "Obsidian plugin capturing CodeMirror 6 editing deltas as an append-only event log. Personal infrastructure.",
	"main": "main.js",
	"type": "module",
	"private": true,
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"version": "node version-bump.mjs && git add manifest.json versions.json",
		"lint": "eslint .",
		"test": "vitest run",
		"test:watch": "vitest"
	},
	"keywords": [],
	"license": "UNLICENSED",
	"devDependencies": {
		"@codemirror/state": "^6.4.1",
		"@codemirror/view": "^6.26.3",
		"@types/node": "^20.12.0",
		"esbuild": "0.25.5",
		"eslint-plugin-obsidianmd": "0.1.9",
		"globals": "14.0.0",
		"tslib": "2.4.0",
		"typescript": "^5.8.3",
		"typescript-eslint": "8.35.1",
		"@eslint/js": "9.30.1",
		"jiti": "2.6.1",
		"vitest": "^2.1.0"
	},
	"dependencies": {
		"obsidian": "latest"
	}
}
